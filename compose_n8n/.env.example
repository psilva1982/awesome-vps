# Domínio público atendido pelo Traefik global (traefik_public)
DOMAIN=n8n.dmain.com

# PostgreSQL — serviço externo, apenas a conexão é feita por aqui
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres.exemplo.internal
DB_POSTGRESDB_PORT=5432
POSTGRES_USER=n8n
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=n8n

# SSL exigido pelo Postgres externo. Por padrão valida a cadeia de certificados
# (REJECT_UNAUTHORIZED=true) — mais seguro contra MITM que sslmode=require puro.
# IMPORTANTE: com REJECT_UNAUTHORIZED=true o driver também valida se
# DB_POSTGRESDB_HOST bate com o SAN/CN do certificado do Postgres. Se você
# conecta por um nome/IP interno diferente do domínio do certificado, a conexão
# será rejeitada mesmo com CA confiável (ex: Let's Encrypt) — use o mesmo
# domínio do certificado aqui, ou mapeie-o para o IP interno via extra_hosts.
#
# Se o provedor usa uma CA própria (ex: RDS, Cloud SQL), coloque o arquivo em
# ./certs/ (montado em /certs dentro do container) e aponte o caminho abaixo,
# ex: DB_POSTGRESDB_SSL_CA_FILE=/certs/ca.crt
# Só defina REJECT_UNAUTHORIZED=false em ambientes de teste/local sem CA confiável.
DB_POSTGRESDB_SSL_ENABLED=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=true
DB_POSTGRESDB_SSL_CA_FILE=

# Chave de criptografia do n8n — gere com: openssl rand -hex 32
# DEVE ser idêntica em main e workers e NUNCA mudar depois de criada.
N8N_ENCRYPTION_KEY=troque-por-32-bytes-hex

# Redis — instância per-app do stack postgres_redis (TLS, porta a partir de 6380).
# Credenciais geradas por create_app_redis.sh -o <file> no VPS de banco.
EXECUTIONS_MODE=queue
QUEUE_BULL_REDIS_HOST=postgres.exemplo.internal
QUEUE_BULL_REDIS_PORT=6380
QUEUE_BULL_REDIS_PASSWORD=troque-esta-senha
QUEUE_BULL_REDIS_TLS=true
GENERIC_TIMEZONE=America/Sao_Paulo
N8N_PROTOCOL=https
N8N_PORT=5678
N8N_PROXY_HOPS=1
N8N_RUNNERS_ENABLED=true
